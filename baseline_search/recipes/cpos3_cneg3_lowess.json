{
  "schema_version": 1,
  "description": "Grid sweep: AsymmetricTukeyBiweight(c_pos=3, c_neg=3), LOWESS fluctuations. All other params identical to first_try.",
  "model": {
    "kind": "biexp_bright_v1"
  },
  "x0": {
    "kind": "biexp_bright_default",
    "b_init_from": "mean_F_minus_long_baseline",
    "b_init_value": null,
    "t_fast_init": 60.0,
    "t_slow_init_from": "t_max/2",
    "t_bright_init_from": "t_max/2"
  },
  "sigma": {
    "kind": "noise_std",
    "method": "mad"
  },
  "bounds": {
    "kind": "biexp_bright_default",
    "t_high_factor": 5.0,
    "t_fast_max": 300.0,
    "t_slow_min": 300.0,
    "t_bright_min": 300.0,
    "t_fast_min": 1.0
  },
  "M": {
    "kind": "AsymmetricTukeyBiweight",
    "c_pos": 3,
    "c_neg": 3
  },
  "fluctuations": {
    "method": "lowess",
    "mode": "ratio",
    "frac": 0.1,
    "M": {
      "kind": "same_as_trend"
    },
    "maxiter": 5,
    "tol": 0.001
  },
  "fit": {
    "backend": "jax",
    "dtype": "float32",
    "maxiter": 5,
    "tol": 0.001,
    "optimizer_options": {
      "maxiter": 20000,
      "ftol": 1e-12,
      "gtol": 1e-10
    }
  }
}
